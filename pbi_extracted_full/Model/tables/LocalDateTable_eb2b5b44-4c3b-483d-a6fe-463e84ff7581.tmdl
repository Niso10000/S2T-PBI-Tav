	partition LocalDateTable_eb2b5b44-4c3b-483d-a6fe-463e84ff7581-cfdbccdf-252d-4179-8a75-902c27e5867d = calculated
		mode: import
		source = Calendar(Date(Year(MIN('DimDate'[End of Week])), 1, 1), Date(Year(MAX('DimDate'[End of Week])), 12, 31))

