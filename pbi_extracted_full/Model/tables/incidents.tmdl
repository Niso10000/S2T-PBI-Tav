table incidents

	measure 'כמות פניות' = DISTINCTCOUNT(incidents[incidentid])
		formatString: #,0

		changedProperty = FormatString

	measure 'כמות פניות חורגות' = CALCULATE([כמות פניות],incidents[pws_slastatus]=1)
		formatString: #,0

		changedProperty = FormatString

	measure 'כמות פניות פתוחות' = CALCULATE([כמות פניות],incidents[statecode]=0)
		formatString: #,0

		changedProperty = FormatString

	measure 'כמות פניות סגורות' = CALCULATE([כמות פניות],incidents[statecode]<>0)
		formatString: #,0

		changedProperty = FormatString

	measure 'כמות פניות מתגלגלות' = CALCULATE([כמות פניות],incidents[pws_noofcaserollings]<> BLANK())
		formatString: #,0

		changedProperty = FormatString

	measure 'אחוז פניות חורגות' = DIVIDE([כמות פניות חורגות],[כמות פניות],BLANK())
		formatString: 0%;-0%;0%

		changedProperty = FormatString

	measure 'אחוז פניות חורגות לפי יום נפה' =
			DIVIDE(
			    sumx(
			SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value],"כמות פניות חורגות",[כמות פניות חורגות]),
			[כמות פניות חורגות]),
			sumx(
			SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value],"כמות פניות",[כמות פניות]),
			[כמות פניות])
			,BLANK())
		formatString: 0%;-0%;0%

		changedProperty = FormatString

	measure 'ציון לפניות' =
			100-
			if([אחוז פניות חורגות לפי יום נפה]>[כלל לניקוד פניות 11],[ניקוד ציון לפניות 11])-
			if([אחוז פניות שנפתחו מחדש לפי יום נפה]>[כלל לניקוד פניות 14],[ניקוד ציון לפניות 14])
		formatString: 0

	measure 'ציון ממוצע לפניות' = AVERAGEx(SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value]),[ציון לפניות])
		formatString: 0

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'ציון ממוצע כל הנפות לפניות' = CALCULATE([ציון ממוצע לפניות],REMOVEFILTERS(V_TAV_Regions))
		formatString: 0

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'כמות לחישוב ממוצע משוקלל_פניות' = COUNTROWS(SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value]))
		formatString: 0

	measure 'אחוז שינוי ציון ממוצע לפניות' = DIVIDE([ציון ממוצע לפניות]-[ציון ממוצע כל הנפות לפניות],[ציון ממוצע כל הנפות לפניות],BLANK())
		formatString: 0%;-0%;0%

		changedProperty = FormatString

