		source =
				let
				    Source = OData.Feed("https://<CRM-HOST>.api.crm4.dynamics.com/api/data/v9.1/incidents?$select=incidentid,pws_contactid,description,_pws_streetid_value,pws_noofcaserollings,pws_status,pws_returncase,_pws_quaterid_value,_pws_casesubjectid_value,_pws_siteid_value,casetypecode,pws_caseduration,pws_caseorigincode,pws_casetype,_pws_neighborhoodid_value,statecode,ticketnumber,createdon,_pws_administration_value,pws_slastatus,_pws_administrationid_value,pws_casenumber,pws_closedateincident,_pws_departmentid_value,pws_acceptorigin,caseorigincode,_pws_divisionid_value,pws_duplicatecase,pws_duplicationdetected,pws_resolvedbyexpiredtime,pws_closedateincident,pws_urgency,pws_sla,_slaid_value,_pws_closereasonid2_value&$filter=(pws_casetype eq 2 or pws_casetype eq 3) and _pws_divisionid_value eq '<DIVISION-GUID>' and createdon ge 2022-01-01", null, [Implementation="2.0"]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"createdon", type datetime}}),
