table pws_caselogs

	measure 'כמות פניות שנפתחו מחדש' = DISTINCTCOUNT(pws_caselogs[_pws_caseid_value])
		formatString: #,0

		changedProperty = FormatString

	measure 'אחוז פניות שנפתחו מחדש' = DIVIDE([כמות פניות שנפתחו מחדש],[כמות פניות],BLANK())
		formatString: 0%;-0%;0%

		changedProperty = FormatString

	measure 'אחוז פניות שנפתחו מחדש לפי יום נפה' =
			DIVIDE(
			    sumx(
			SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value],"כמות פניות שנפתחו מחדש",[כמות פניות שנפתחו מחדש]),
			[כמות פניות שנפתחו מחדש]),
			sumx(
			SUMMARIZE(incidents,incidents[createdon],incidents[_pws_departmentid_value],"כמות פניות",[כמות פניות]),
			[כמות פניות])
			,BLANK())
		formatString: 0%;-0%;0%

		changedProperty = FormatString

	column pws_currentstatus
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: pws_currentstatus

		annotation SummarizationSetBy = Automatic

