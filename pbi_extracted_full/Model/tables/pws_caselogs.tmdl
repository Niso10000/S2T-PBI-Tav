				    Source = OData.Feed("https://<CRM-HOST>.api.crm4.dynamics.com/api/data/v9.1/pws_caselogs?$select=_pws_currentdepartmentid_value,createdon,_pws_currentdepartmentid_value,_pws_prevdepartmentid_value,_pws_caseid_value,statuscode,_pws_currentsubjectid_value,_pws_prevsubjectid_value,pws_currentstatus,_pws_caseid_value,pws_caselogid,pws_previousstatus&$filter= pws_previousstatus eq 14", null, [Implementation="2.0"])
